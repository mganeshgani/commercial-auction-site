# Server Port
PORT=5001

# Node Environment
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb+srv://your-connection-string-here

# JWT Secret (use a long random string, minimum 32 characters)
JWT_SECRET=your_long_random_secret_minimum_32_characters

# Image Upload Directory
# Local: ./uploads (relative, for development)
# Production: /var/www/uploads (absolute, on droplet)
UPLOAD_DIR=./uploads

# Backend Base URL (used for constructing image URLs)
# Local: http://localhost:5001
# Production: https://api.yourdomain.com
BASE_URL=http://localhost:5001

# Frontend URL (for CORS and registration links)
FRONTEND_URL=http://localhost:3000
